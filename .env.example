# Copy to .env and fill in for notarized release builds.
#
# These are only needed for `npm run build:app` (DMG production).
# Local `npm run dev` does NOT need any of this.

# Your Apple Developer account email
APPLE_ID=marcel_noel@gmx.net

# Generated at https://appleid.apple.com/ → "Sign-in and Security"
#   → "App-Specific Passwords" → "+"
# Format: xxxx-xxxx-xxxx-xxxx
APPLE_APP_SPECIFIC_PASSWORD=

# 10-char Team ID from https://developer.apple.com/account/ → Membership
APPLE_TEAM_ID=

# Identity string from your Keychain — usually:
#   Developer ID Application: <your name> (<APPLE_TEAM_ID>)
# Run `security find-identity -p codesigning -v` to list installed certs.
# If unset, electron-builder auto-selects the first Developer ID it finds.
CSC_NAME=
