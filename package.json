{
  "name": "cc-chamber",
  "version": "0.2.0",
  "description": "A clean desktop room for Claude Code — terminal + markdown chat + file browser, in the Open-Chamber style",
  "main": "electron/main.mjs",
  "type": "module",
  "bin": {
    "cc-chamber": "bin/cc-chamber.mjs"
  },
  "scripts": {
    "start": "node bin/cc-chamber.mjs",
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env CC_CHAMBER_DEV=1 electron .",
    "build": "tsc -b && vite build",
    "build:app": "npm run build && node -r dotenv/config node_modules/.bin/electron-builder",
    "build:app:adhoc": "CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder -c.mac.identity=- -c.mac.notarize=false",
    "rebuild": "cd node_modules/node-pty && npm_config_target=42.1.0 npm_config_arch=arm64 npm_config_target_arch=arm64 npm_config_disturl=https://electronjs.org/headers npm_config_runtime=electron npm_config_build_from_source=true node-gyp rebuild",
    "postinstall": "npm run rebuild"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marcel-I-T/cc-chamber.git"
  },
  "homepage": "https://github.com/Marcel-I-T/cc-chamber",
  "bugs": {
    "url": "https://github.com/Marcel-I-T/cc-chamber/issues"
  },
  "license": "MIT",
  "author": "Marcel",
  "keywords": [
    "claude-code",
    "anthropic",
    "electron",
    "terminal",
    "chat",
    "desktop",
    "developer-tool",
    "ai-coding"
  ],
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "node-gyp": "^11.2.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "dev.cc-chamber.desktop",
    "productName": "cc-chamber",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "files": [
      "dist/**",
      "electron/**",
      "bin/**",
      "assets/**",
      "package.json",
      "node_modules/node-pty/build/Release/pty.node",
      "node_modules/node-pty/build/Release/spawn-helper"
    ],
    "mac": {
      "target": {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      },
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    }
  }
}
